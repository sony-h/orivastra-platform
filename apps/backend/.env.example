# ──────────────────────────────────────────────
# Backend — Environment Variables
# ──────────────────────────────────────────────
# Copy to /etc/orivastra.env on the VPS and fill
# in real values. Never commit /etc/orivastra.env.
#
# PM2 reads this file via ecosystem.config.js's
# env_file option.
# ──────────────────────────────────────────────

NODE_ENV=production
PORT=3001

# Database — PostgreSQL runs in Docker
DATABASE_URL=postgresql://orivastra:CHANGE_ME@localhost:5432/orivastra

# Cache — Redis runs in Docker
REDIS_URL=redis://localhost:6379

# JWT secret — generate with: openssl rand -base64 64
JWT_SECRET=CHANGE_ME
