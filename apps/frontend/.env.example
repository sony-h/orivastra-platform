# ──────────────────────────────────────────────
# Frontend — Environment Variables
# ──────────────────────────────────────────────
# Copy to /etc/orivastra.env on the VPS along
# with backend vars. Never commit this file.
#
# PM2 reads this file via ecosystem.config.js's
# env_file option.
# ──────────────────────────────────────────────

NODE_ENV=production

# Public API URL — client-side requests go here
NEXT_PUBLIC_API_URL=https://orivastra.com/api
