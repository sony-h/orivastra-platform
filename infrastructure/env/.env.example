# ──────────────────────────────────────────────
# Orivastra — Infrastructure Environment Example
# ──────────────────────────────────────────────
# These variables are for Docker infrastructure
# services (PostgreSQL, Redis, Adminer).
#
# Application environment variables are defined
# in apps/backend/.env.example and
# apps/frontend/.env.example.
#
# On the VPS, create /etc/orivastra.env with
# both infra and app vars combined.
# ──────────────────────────────────────────────

# Database
POSTGRES_DB=orivastra
POSTGRES_USER=orivastra
POSTGRES_PASSWORD=CHANGE_ME
