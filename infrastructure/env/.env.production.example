# ──────────────────────────────────────────────
# Orivastra — Production Environment Template
# ──────────────────────────────────────────────
# Copy to .env on the production server.
# Replace every CHANGE_ME with a real secret.
# Never commit the real .env to version control.
#
# Generate strong passwords:
#   openssl rand -base64 32
#
# Generate JWT secret:
#   openssl rand -base64 64

# ── Database ─────────────────────────────────
# PostgreSQL credentials.
# The database runs inside Docker on the same VPS.
# It is NOT exposed to the public internet.
DATABASE_URL=postgresql://orivastra:CHANGE_ME@postgres:5432/orivastra
POSTGRES_DB=orivastra
POSTGRES_USER=orivastra
POSTGRES_PASSWORD=CHANGE_ME

# ── Redis ────────────────────────────────────
# Redis runs inside Docker on the same VPS.
# It is NOT exposed to the public internet.
REDIS_URL=redis://redis:6379

# ── Backend ──────────────────────────────────
# NestJS listens on this port inside the container.
# Nginx proxies external traffic to it.
PORT=3001
NODE_ENV=production

# JWT secret for future authentication.
# Generate with: openssl rand -base64 64
JWT_SECRET=CHANGE_ME

# ── Frontend ─────────────────────────────────
# Public API URL for client-side requests.
# Set to your domain in production:
#   https://orivastra.com/api
NEXT_PUBLIC_API_URL=https://orivastra.com/api

# ── Domain (future) ──────────────────────────
# DOMAIN=orivastra.com
# CLOUDFLARE_API_TOKEN=CHANGE_ME
